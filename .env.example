# Copy to .env and customize before running `docker compose up`.

# --- SQL Server ---
MSSQL_SA_PASSWORD=ChangeMe_Str0ngPass!
MSSQL_PORT=1433

# --- JWT ---
# Generate a 64-byte random key:  openssl rand -base64 64
JWT_SIGNING_KEY=replace-with-base64-64-bytes
JWT_ISSUER=openquiz
JWT_AUDIENCE=openquiz
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30

# --- Google Sign-In ---
# Create at https://console.cloud.google.com/apis/credentials → "OAuth 2.0 Client IDs" (Web)
# Authorized JavaScript origins must include PUBLIC_URL.
GOOGLE_CLIENT_ID=

# --- SMTP (optional; required only for password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@openquiz.local
SMTP_FROM_NAME=OpenQuiz
SMTP_USE_STARTTLS=true

# --- App ---
ADMIN_EMAIL=
PUBLIC_URL=http://localhost:8080
WEB_PORT=8080
API_PORT=5080

# Backend URL the React app calls. Leave empty: nginx in the web container
# reverse-proxies /api and /hubs to the api service, so the frontend uses
# relative URLs and works on any LAN IP/hostname automatically.
VITE_API_BASE_URL=
ASPNETCORE_ENVIRONMENT=Production
